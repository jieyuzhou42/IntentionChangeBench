AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_RESPONSES_ENDPOINT=https://your-resource-name.cognitiveservices.azure.com/openai/responses?api-version=2025-04-01-preview
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Legacy alternative if you want chat/completions instead of a full responses URL:
# AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
# AZURE_OPENAI_CHAT_DEPLOYMENT=your-chat-deployment-name

# Optional WebShop reranking. BM25 still retrieves candidates first; Jina reranks
# the top 50 when JINA_API_KEY is present, unless WEBSHOP_JINA_RERANK=0.
JINA_API_KEY=your-jina-api-key
WEBSHOP_JINA_RERANK=1
WEBSHOP_JINA_RERANK_MODEL=jina-reranker-v3
WEBSHOP_JINA_RERANK_TOP_N=50
WEBSHOP_JINA_RERANK_MAX_DOC_CHARS=1200
WEBSHOP_JINA_RERANK_MIN_INTERVAL=8
WEBSHOP_JINA_RERANK_MAX_RETRIES=3
WEBSHOP_JINA_RERANK_RETRY_BACKOFF=1
# Optional diagnostics for tracking which code path/query calls Jina.
# WEBSHOP_JINA_RERANK_VERBOSE=1
# WEBSHOP_JINA_RERANK_LOG_PATH=IntentionChangeBench/data/jina_rerank_calls.jsonl
